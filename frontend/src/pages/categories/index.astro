---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import fetchStrapiPosts from "@/utils/fetchStrapiPosts";
import { slugifyStr } from "@/utils/slugify";

const localPosts = await getCollection("blog", ({ data }) => !data.draft);
const strapiPosts = await fetchStrapiPosts();
const posts = [...localPosts, ...strapiPosts] as any[];

// Filter out unique categories from Strapi
const categories = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
---

<Layout title={`Categories | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Categories" pageDesc="Browse posts by category.">
    <ul class="flex flex-col space-y-4">
      {categories.map(category => (
        <li>
          <a
            href={`/categories/${slugifyStr(category)}`}
            class="inline-block text-lg font-medium text-skin-accent decoration-dashed underline-offset-4 hover:text-skin-base"
          >
            <span class="text-xl">&#8250;</span> {category}
          </a>
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>